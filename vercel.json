{
  "builds": [
    {
      "src": "*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/demo/?", "dest": "/demo.html" },
    { "src": "/about/?", "dest": "/about.html" },
    { "src": "/waitlistsignup/?", "dest": "/waitlistsignup.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "cleanUrls": false,
  "trailingSlash": false
}