{
  "builds": [
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "assets/**",
      "use": "@vercel/static"
    }
  ],
  "headers": [
    {
      "source": "/sitemap\\.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        }
      ]
    },
    {
      "source": "/robots\\.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        }
      ]
    },
    {
      "source": "/(.*)\\.svg",
      "headers": [
        {
          "key": "Content-Type",
          "value": "image/svg+xml; charset=utf-8"
        }
      ]
    }
  ],
  "routes": [
    { "src": "/sitemap\\.xml", "dest": "/api/sitemap.js" },
    { "handle": "filesystem" },
    { "src": "/assets/logo_homepage\\.svg", "dest": "/assets/logo_homepage.svg" },
    { "src": "/demo/?", "dest": "/demo.html" },
    { "src": "/product/?", "dest": "/product.html" },
    { "src": "/about/?", "dest": "/about.html" },
    { "src": "/waitlistsignup/?", "dest": "/waitlistsignup.html" },
    { "src": "/blog/?", "dest": "/blog.html" },
    { "src": "/blog/posts/([^/]+)", "dest": "/blog/posts/$1.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "cleanUrls": false,
  "trailingSlash": false
}
