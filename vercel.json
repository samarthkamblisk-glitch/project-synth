{
  "builds": [
    {
      "src": "*.html",
      "use": "@vercel/static"
    }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain"
        }
      ]
    },
    {
      "source": "/(.*\\.txt)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain"
        }
      ]
    },
    {
      "source": "/(.*\\.xml)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        }
      ]
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/demo/?", "dest": "/demo.html" },
    { "src": "/about/?", "dest": "/about.html" },
    { "src": "/waitlistsignup/?", "dest": "/waitlistsignup.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "cleanUrls": false,
  "trailingSlash": false
}